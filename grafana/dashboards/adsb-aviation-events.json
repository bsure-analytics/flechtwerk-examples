    {
      "id": 5,
      "type": "table",
      "title": "Live events feed",
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "gridPos": { "h": 13, "w": 14, "x": 0, "y": 4 },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": { "showHeader": true },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
          "editorType": "sql",
          "queryType": "table",
          "format": 1,
          "rawSql": "SELECT at, event_type, hex, trimBoth(flight) AS callsign, requested_region, detail FROM flechtwerk.adsb_events ORDER BY at DESC LIMIT 200"
