    {
      "id": 7,
      "type": "table",
      "title": "Busiest airlines (in view)",
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 17 },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": { "showHeader": true, "sortBy": [{ "displayName": "aircraft", "desc": true }] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
          "editorType": "sql",
          "queryType": "table",
          "format": 1,
          "rawSql": "SELECT airline, count() AS aircraft FROM flechtwerk.adsb_aircraft FINAL WHERE is_deleted = 0 AND airline != '' GROUP BY airline ORDER BY aircraft DESC LIMIT 20"
        }
      ]
    },
    {
      "id": 8,
      "type": "table",
      "title": "Aircraft by country (in view)",
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 17 },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": { "showHeader": true, "sortBy": [{ "displayName": "aircraft", "desc": true }] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
          "editorType": "sql",
          "queryType": "table",
          "format": 1,
          "rawSql": "SELECT over_country AS country, count() AS aircraft FROM flechtwerk.adsb_aircraft FINAL WHERE is_deleted = 0 AND over_country != '' GROUP BY over_country ORDER BY aircraft DESC LIMIT 20"
