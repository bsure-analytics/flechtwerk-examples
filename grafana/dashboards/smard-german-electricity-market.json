{
  "uid": "flechtwerk-smard",
  "title": "Flechtwerk — SMARD German Electricity Market",
  "tags": ["flechtwerk", "smard"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "1m",
  "time": { "from": "now-24h", "to": "now+36h" },
  "timepicker": {},
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Renewables share (latest)",
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "decimals": 0, "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 0.3 }, { "color": "green", "value": 0.5 }] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
          "editorType": "sql",
          "queryType": "table",
          "format": 1,
          "rawSql": "SELECT renewables_share FROM flechtwerk.smard_mix FINAL WHERE renewables_share IS NOT NULL AND n_sources >= (SELECT max(n_sources) FROM flechtwerk.smard_mix) ORDER BY ts DESC LIMIT 1"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "CO₂ intensity (latest, g/kWh)",
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "none", "decimals": 0, "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 300 }, { "color": "red", "value": 500 }] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
          "editorType": "sql",
          "queryType": "table",
          "format": 1,
          "rawSql": "SELECT co2_g_per_kwh FROM flechtwerk.smard_mix FINAL WHERE co2_g_per_kwh IS NOT NULL AND n_sources >= (SELECT max(n_sources) FROM flechtwerk.smard_mix) ORDER BY ts DESC LIMIT 1"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Data through (latest observation)",
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "string", "color": { "mode": "fixed", "fixedColor": "blue" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "/.*/" }, "colorMode": "value", "graphMode": "none", "textMode": "value" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
          "editorType": "sql",
          "queryType": "table",
          "format": 1,
          "rawSql": "SELECT formatDateTime(max(ts), '%Y-%m-%d %H:%i', 'UTC') AS latest_observation FROM flechtwerk.smard_observations FINAL WHERE role = 'load'"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Settled through (finalized)",
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "string", "color": { "mode": "fixed", "fixedColor": "green" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "/.*/" }, "colorMode": "value", "graphMode": "none", "textMode": "value" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
          "editorType": "sql",
          "queryType": "table",
          "format": 1,
          "rawSql": "SELECT formatDateTime(max(ts), '%Y-%m-%d %H:%i', 'UTC') AS settled_through FROM flechtwerk.smard_mix FINAL WHERE is_final = 1"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Generation mix by source (GW)",
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "gridPos": { "h": 10, "w": 16, "x": 0, "y": 4 },
      "fieldConfig": { "defaults": { "unit": "gwatt", "decimals": 2, "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 45, "showPoints": "never", "stacking": { "mode": "normal", "group": "A" } } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "transformations": [
        { "id": "partitionByValues", "options": { "fields": ["name"], "keepFields": false } },
        { "id": "renameByRegex", "options": { "regex": "^gw (.*)$", "renamePattern": "$1" } }
      ],
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
          "editorType": "sql",
          "queryType": "timeseries",
          "format": 2,
          "rawSql": "SELECT ts AS time, name, value / 250 AS gw FROM flechtwerk.smard_observations FINAL WHERE role = 'source' AND $__timeFilter(ts) ORDER BY time"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Day-ahead price (€/MWh) — publishes a day ahead",
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "gridPos": { "h": 10, "w": 8, "x": 16, "y": 4 },
      "fieldConfig": { "defaults": { "unit": "none", "decimals": 1, "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "showPoints": "never", "spanNulls": true } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
          "editorType": "sql",
          "queryType": "timeseries",
          "format": 1,
          "rawSql": "SELECT ts AS time, price_eur_mwh AS \"Price €/MWh\" FROM flechtwerk.smard_mix FINAL WHERE price_eur_mwh IS NOT NULL AND $__timeFilter(ts) ORDER BY time"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Load vs residual load (GW)",
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 14 },
      "fieldConfig": { "defaults": { "unit": "gwatt", "decimals": 2, "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "showPoints": "never", "spanNulls": true } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
          "editorType": "sql",
          "queryType": "timeseries",
          "format": 1,
          "rawSql": "SELECT ts AS time, load_mwh / 250 AS \"Load\", residual_load_mwh / 250 AS \"Residual load\" FROM flechtwerk.smard_mix FINAL WHERE load_mwh IS NOT NULL AND $__timeFilter(ts) ORDER BY time"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Renewables share over time",
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 14 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "decimals": 0, "min": 0, "max": 1, "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 20, "showPoints": "never", "spanNulls": true } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
          "editorType": "sql",
          "queryType": "timeseries",
          "format": 1,
          "rawSql": "SELECT ts AS time, renewables_share AS \"Renewables\" FROM flechtwerk.smard_mix FINAL WHERE renewables_share IS NOT NULL AND n_sources >= (SELECT max(n_sources) FROM flechtwerk.smard_mix) AND $__timeFilter(ts) ORDER BY time"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "CO₂ intensity over time (g/kWh)",
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 14 },
      "fieldConfig": { "defaults": { "unit": "none", "decimals": 0, "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 20, "showPoints": "never", "spanNulls": true } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
          "editorType": "sql",
          "queryType": "timeseries",
          "format": 1,
          "rawSql": "SELECT ts AS time, co2_g_per_kwh AS \"g CO₂/kWh\" FROM flechtwerk.smard_mix FINAL WHERE co2_g_per_kwh IS NOT NULL AND n_sources >= (SELECT max(n_sources) FROM flechtwerk.smard_mix) AND $__timeFilter(ts) ORDER BY time"
        }
      ]
    },
    {
      "id": 10,
      "type": "table",
      "title": "Corrections feed — SMARD restating recent values (the late-data theme)",
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "gridPos": { "h": 10, "w": 14, "x": 0, "y": 22 },
      "fieldConfig": { "defaults": { "decimals": 1 }, "overrides": [] },
      "options": { "showHeader": true, "sortBy": [{ "displayName": "corrected_at", "desc": true }] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
          "editorType": "sql",
          "queryType": "table",
          "format": 1,
          "rawSql": "SELECT fetched_at AS corrected_at, name, ts AS interval, round(previous_value, 1) AS previous, round(value, 1) AS corrected, round(value - previous_value, 1) AS delta FROM flechtwerk.smard_revisions WHERE $__timeFilter(fetched_at) ORDER BY fetched_at DESC LIMIT 200"
        }
      ]
    },
    {
      "id": 11,
      "type": "barchart",
      "title": "Corrections per series",
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "gridPos": { "h": 10, "w": 10, "x": 14, "y": 22 },
      "fieldConfig": { "defaults": { "unit": "none", "color": { "mode": "palette-classic" } }, "overrides": [] },
      "options": { "orientation": "horizontal", "xField": "name", "legend": { "showLegend": false } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
          "editorType": "sql",
          "queryType": "table",
          "format": 1,
          "rawSql": "SELECT name, count() AS revisions FROM flechtwerk.smard_revisions WHERE $__timeFilter(fetched_at) GROUP BY name ORDER BY revisions DESC"
        }
      ]
    },
    {
      "id": 12,
      "type": "table",
      "title": "Series freshness (latest interval per series vs now)",
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 32 },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": { "showHeader": true, "sortBy": [{ "displayName": "latest_interval", "desc": true }] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
          "editorType": "sql",
          "queryType": "table",
          "format": 1,
          "rawSql": "SELECT name, role, max(ts) AS latest_interval, round(dateDiff('minute', max(ts), now()) / 60.0, 1) AS hours_behind FROM flechtwerk.smard_observations FINAL GROUP BY name, role ORDER BY name"
        }
      ]
    }
  ]
}
