      ],
      "keepFields": false
     }
    },
    {
     "id": "renameByRegex",
     "options": {
      "regex": "^net_edge (.*)$",
      "renamePattern": "$1"
     }
    }
   ],
   "targets": [
    {
     "refId": "A",
     "datasource": {
      "type": "grafana-clickhouse-datasource",
      "uid": "clickhouse"
     },
     "editorType": "sql",
     "queryType": "timeseries",
     "format": 2,
     "rawSql": "SELECT computed_at AS time, concat(pair_key, ' \u00b7 ', direction) AS series, net_edge FROM flechtwerk.odds_margins WHERE fresh = 1 AND $__timeFilter(computed_at) ORDER BY time"
    }
   ]
