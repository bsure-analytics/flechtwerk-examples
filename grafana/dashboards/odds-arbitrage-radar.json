   "targets": [
    {
     "refId": "A",
     "datasource": {
      "type": "grafana-clickhouse-datasource",
      "uid": "clickhouse"
     },
     "editorType": "sql",
     "queryType": "table",
     "format": 1,
     "rawSql": "SELECT pair_key, direction, argMax(net_edge, computed_at) AS net_edge, argMax(gross_edge, computed_at) AS gross_edge, max(computed_at) AS as_of FROM flechtwerk.odds_margins WHERE fresh = 1 AND $__timeFilter(computed_at) GROUP BY pair_key, direction ORDER BY net_edge DESC"
    }
   ]
