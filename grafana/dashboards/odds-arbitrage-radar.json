   "targets": [
    {
     "refId": "A",
     "datasource": {
      "type": "grafana-clickhouse-datasource",
      "uid": "clickhouse"
     },
     "editorType": "sql",
     "queryType": "timeseries",
     "format": 2,
     "rawSql": "SELECT time, concat(direction, ' ', metric) AS series, v FROM (  SELECT computed_at AS time, direction, 'gross' AS metric, gross_edge AS v   FROM flechtwerk.odds_margins WHERE pair_key = '$pair' AND $__timeFilter(computed_at)  UNION ALL   SELECT computed_at AS time, direction, 'net' AS metric, net_edge AS v   FROM flechtwerk.odds_margins WHERE pair_key = '$pair' AND $__timeFilter(computed_at)) ORDER BY time"
    }
   ]
