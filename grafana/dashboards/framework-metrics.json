{
  "uid": "flechtwerk-framework",
  "title": "Flechtwerk — Framework Metrics",
  "tags": ["flechtwerk"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "example",
        "label": "Example",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(example)",
        "query": { "query": "label_values(example)", "refId": "example" },
        "includeAll": true,
        "multi": true,
        "allValue": ".*",
        "current": { "text": "All", "value": "$__all" },
        "refresh": 2,
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Messages in / out (per second)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "expr": "sum by (example) (rate(flechtwerk_messages_in_total{example=~\"$example\"}[$__rate_interval]))", "legendFormat": "in — {{example}}" },
        { "refId": "B", "expr": "sum by (example) (rate(flechtwerk_messages_out_total{example=~\"$example\"}[$__rate_interval]))", "legendFormat": "out — {{example}}" }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Transactions committed (per second)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "expr": "sum by (example) (rate(flechtwerk_transactions_committed_total{example=~\"$example\"}[$__rate_interval]))", "legendFormat": "{{example}}" }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Average batch size (transformers)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "expr": "sum by (example) (rate(flechtwerk_batch_size_sum{example=~\"$example\"}[$__rate_interval])) / sum by (example) (rate(flechtwerk_batch_size_count{example=~\"$example\"}[$__rate_interval]))", "legendFormat": "{{example}}" }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "State entries restored (increase)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "bars", "fillOpacity": 40 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "expr": "sum by (example) (increase(flechtwerk_state_restored_entries_total{example=~\"$example\"}[$__rate_interval]))", "legendFormat": "{{example}}" }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Config store entries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "steps": [ { "color": "text", "value": null } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "area", "textMode": "value_and_name" },
      "targets": [
        { "refId": "A", "expr": "sum by (example) (flechtwerk_config_store_entries{example=~\"$example\"})", "legendFormat": "{{example}}", "instant": true }
      ]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Ownership: tokens / tasks assigned",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "steps": [ { "color": "text", "value": null } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "area", "textMode": "value_and_name" },
      "targets": [
        { "refId": "A", "expr": "sum by (example) (flechtwerk_tokens_assigned{example=~\"$example\"})", "legendFormat": "tokens — {{example}}", "instant": true },
        { "refId": "B", "expr": "sum by (example) (flechtwerk_tasks_assigned{example=~\"$example\"})", "legendFormat": "tasks — {{example}}", "instant": true }
      ]
    }
  ]
}
